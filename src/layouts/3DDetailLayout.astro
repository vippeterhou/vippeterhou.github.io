---
import BaseLayout from './BaseLayout.astro'

interface Props {
  title: string
  src: string
  description?: string
}

const { title, src, description } = Astro.props
const skeletonId = `skeleton-${title.toLowerCase().replace(/\W+/g, '-')}`
---

<BaseLayout title={`${title} — Peter Hou`} description="An interactive 3D model">
  <section class="page-section">
    <div class="container">
      <a class="back" href="/studio/3d-collection">&larr; 3D Collection</a>
      <h1 class="model-title">{title}</h1>
      {description && <p class="description">{description}</p>}
      <slot />
      <div class="viewer">
        <div class="viewer-skeleton" id={skeletonId} aria-hidden="true">
          <div class="skeleton" style="width: 100%; height: 100%; border-radius: 12px;"></div>
        </div>
        <iframe
          title={title}
          src={src}
          width="100%"
          height="480"
          frameBorder="0"
          allowfullscreen
          allow="autoplay; fullscreen; xr-spatial-tracking"
          loading="lazy"
          onload={`document.getElementById('${skeletonId}').remove()`}
        ></iframe>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .back {
    display: inline-block;
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
    transition: color var(--transition);
  }

  .back:hover {
    color: var(--accent);
  }

  .model-title {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--nav-color);
  }

  .description {
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-top: 0.5rem;
  }

  .viewer {
    margin-top: 1.5rem;
    border-radius: 12px;
    overflow: hidden;
    max-width: 800px;
    position: relative;
  }

  .viewer iframe {
    display: block;
    border: none;
  }

  .viewer-skeleton {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: var(--bg);
    border-radius: 12px;
  }
</style>
