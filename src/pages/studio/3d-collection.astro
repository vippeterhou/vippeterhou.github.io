---
import BaseLayout from '../../layouts/BaseLayout.astro'
---

<BaseLayout title="3D Collection — Peter Hou" description="Some things were never meant to be seen from just one angle.">
  <section class="page-section">
    <div class="container">
      <h1 class="title">3D Collection</h1>
      <p class="intro">
        Some things were never meant to be seen from just one angle. Here are a few I've picked — spin them around, zoom in, and take your time.
      </p>
      <div class="grid">
        <a class="card" href="/studio/3d-collection/gelato-dreams">
          <div class="preview">
            <div class="viewer-skeleton" id="skeleton-gelato" aria-hidden="true">
              <div class="skeleton" style="width: 100%; height: 100%; border-radius: 8px;"></div>
            </div>
            <iframe
              title="Wishing Machine : Gelato Dreams"
              src="https://sketchfab.com/models/de9c60faed3c489dbdf65850f1ae4c5c/embed?dnt=1"
              width="100%"
              height="240"
              frameBorder="0"
              allow="autoplay; fullscreen; xr-spatial-tracking"
              loading="lazy"
              tabindex="-1"
              onload="document.getElementById('skeleton-gelato').remove()"
            ></iframe>
          </div>
          <p class="model-label">Wishing Machine: Gelato Dreams</p>
        </a>

        <a class="card" href="/studio/3d-collection/mountain-scroll">
          <div class="preview">
            <div class="viewer-skeleton" id="skeleton-scroll" aria-hidden="true">
              <div class="skeleton" style="width: 100%; height: 100%; border-radius: 8px;"></div>
            </div>
            <iframe
              title="Mountain And River Scroll"
              src="https://sketchfab.com/models/dd37769bdc0148a988535f893d01c551/embed?dnt=1"
              width="100%"
              height="240"
              frameBorder="0"
              allow="autoplay; fullscreen; xr-spatial-tracking"
              loading="lazy"
              tabindex="-1"
              onload="document.getElementById('skeleton-scroll').remove()"
            ></iframe>
          </div>
          <p class="model-label">Mountain and River Scroll</p>
        </a>

        <a class="card" href="/studio/3d-collection/chinese-table">
          <div class="preview">
            <div class="viewer-skeleton" id="skeleton-table" aria-hidden="true">
              <div class="skeleton" style="width: 100%; height: 100%; border-radius: 8px;"></div>
            </div>
            <iframe
              title="Chinese square table"
              src="https://sketchfab.com/models/7aa5de5b5d174784a8354ce468425f7c/embed?dnt=1"
              width="100%"
              height="240"
              frameBorder="0"
              allow="autoplay; fullscreen; xr-spatial-tracking"
              loading="lazy"
              tabindex="-1"
              onload="document.getElementById('skeleton-table').remove()"
            ></iframe>
          </div>
          <p class="model-label">Chinese Square Table</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .card {
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    background: var(--bg-secondary);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    display: block;
    color: inherit;
  }

  .card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  .preview {
    position: relative;
    pointer-events: none;
  }

  .preview iframe {
    display: block;
    border: none;
  }

  .model-label {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    padding: 0.75rem 1rem;
  }

  .viewer-skeleton {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: var(--bg);
  }
</style>
