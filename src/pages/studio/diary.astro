---
import BaseLayout from '../../layouts/BaseLayout.astro'
import DiaryEntry from '../../components/DiaryEntry.svelte'
---

<BaseLayout title="Metropolitan Diary — Peter Hou" description="A Metropolitan Diary entry from the New York Times">
  <section class="page-section">
    <div class="container">

      <div class="header">
        <p class="label">The New York Times</p>
        <h1 class="title">Metropolitan Diary</h1>
        <p class="intro">
          As a New York Times (NYT) subscriber, one of my favorite sections is the Metropolitan Diary
          (I know — shouldn't I pay more attention to the news itself?).
          The stories are told by New Yorkers about their everyday lives, dispatched by NYT on a weekly basis.
          Some are funny, some are tender, some are wonderfully absurd — together, they capture the spirit of the city. I love it.
        </p>
      </div>

      <DiaryEntry client:load />

    </div>
  </section>
</BaseLayout>

<style>
  .header {
    margin-bottom: 2rem;
  }

  .label {
    font-size: 0.8125rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.375rem;
  }

  .title {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .intro {
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.7;
  }
</style>
