---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Minesweeper from '../../components/Minesweeper.svelte'
---

<BaseLayout title="Minesweeper — Peter Hou" description="Classic Minesweeper">
  <section class="page-section">
    <div class="container">
      <h1 class="title">Minesweeper</h1>
      <p class="intro">Left-click to reveal · Right-click to flag · Clear all mines to win.</p>
      <Minesweeper client:only="svelte" />
    </div>
  </section>
</BaseLayout>

<style>
  .intro {
    margin-bottom: 2rem;
  }
</style>
