---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Minesweeper from '../../components/Minesweeper.svelte'
---

<BaseLayout title="Minesweeper — Peter Hou" description="Classic Minesweeper">
  <section class="page-section">
    <div class="container">
      <h1 class="title">Minesweeper</h1>
      <p class="intro">
        Getting tired? Kill some time with this simple classic. Have fun!
      </p>
      <p class="tutorial">Left-click to reveal · Right-click to flag · Clear all mines to win.</p>
      <Minesweeper client:only="svelte" />
    </div>
  </section>
</BaseLayout>

<style>
  .tutorial {
    font-size: 0.8125rem;
    color: var(--text-muted);
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    text-align: center;
  }
</style>
