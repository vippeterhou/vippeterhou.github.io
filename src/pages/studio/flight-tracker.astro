---
import BaseLayout from '../../layouts/BaseLayout.astro'
---

<BaseLayout title="Flight Tracker — Peter Hou" description="Live flight tracker">
  <section class="page-section">
    <div class="container">
      <h1 class="title">Flight Tracker</h1>
    </div>
  </section>
  <div class="embed">
    <iframe
      src="https://myflighttracker.fly.dev/"
      title="Flight Tracker"
      allowfullscreen
    ></iframe>
  </div>
</BaseLayout>

<style>
  .page-section {
    padding-bottom: 1rem;
  }

  .title {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 0;
    text-align: left;
  }

  .embed {
    flex: 1;
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--border);
  }

  iframe {
    flex: 1;
    width: 100%;
    min-height: 80vh;
    border: none;
  }
</style>
