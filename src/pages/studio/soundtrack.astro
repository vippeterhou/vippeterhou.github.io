---
import BaseLayout from '../../layouts/BaseLayout.astro'
---

<BaseLayout title="Soundtrack — Peter Hou" description="Peter's playlist on Spotify">
  <section class="page-section">
    <div class="container">
      <h1 class="title">Soundtrack</h1>
      <p class="intro">
        Songs that stayed with me. Press play and linger a while.
      </p>
      <div class="player">
        <div class="player-skeleton" id="spotify-skeleton" aria-hidden="true">
          <div class="skel-cover skeleton"></div>
          <div class="skel-tracks">
            <div class="skeleton" style="width: 60%; height: 1.5rem; margin-bottom: 1.25rem;"></div>
            <div class="skeleton" style="width: 80%; height: 1.5rem; margin-bottom: 1.125rem;"></div>
            <div class="skeleton" style="width: 70%; height: 1.5rem; margin-bottom: 1.125rem;"></div>
            <div class="skeleton" style="width: 90%; height: 1.5rem; margin-bottom: 1.125rem;"></div>
            <div class="skeleton" style="width: 65%; height: 1.5rem; margin-bottom: 1.125rem;"></div>
            <div class="skeleton" style="width: 75%; height: 1.5rem; margin-bottom: 1.125rem;"></div>
            <div class="skeleton" style="width: 55%; height: 1.5rem;"></div>
          </div>
        </div>
        <iframe
          src="https://open.spotify.com/embed/playlist/3akwbk03kvh9dFgdunjdKJ?utm_source=generator&theme=0"
          width="100%"
          height="552"
          frameBorder="0"
          allowfullscreen
          allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
          loading="lazy"
          onload="document.getElementById('spotify-skeleton').remove()"
        ></iframe>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .player {
    margin-top: 1.5rem;
    border-radius: 12px;
    overflow: hidden;
    max-width: 640px;
    position: relative;
  }

  .player iframe {
    display: block;
    border: none;
  }

  .player-skeleton {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: var(--bg);
    border-radius: 12px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .skel-cover {
    width: 100%;
    height: 200px;
    border-radius: 8px;
  }

  .skel-tracks {
    display: flex;
    flex-direction: column;
    padding-top: 0.5rem;
  }
</style>
