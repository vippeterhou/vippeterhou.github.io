---
import BaseLayout from '../layouts/BaseLayout.astro'

const services = [
  {
    category: 'Hosting',
    items: [
      {
        name: 'GitHub Repository',
        description: 'Source code and git history.',
        href: 'https://github.com/vippeterhou/vippeterhou.github.io',
      },
      {
        name: 'GitHub Actions',
        description: 'Automated deploy pipeline — runs on every push to main.',
        href: 'https://github.com/vippeterhou/vippeterhou.github.io/actions',
      },
    ],
  },
  {
    category: 'Analytics',
    items: [
      {
        name: 'Google Analytics',
        description: 'Tag G-DDDLNKD2YC installed.',
        href: 'https://analytics.google.com',
      },
      {
        name: 'Cloudflare',
        description: 'CDN and DNS management.',
        href: 'https://dash.cloudflare.com',
      },
    ],
  },
  {
    category: 'Media',
    items: [
      {
        name: 'Cloudinary',
        description: 'Manage image assets.',
        href: 'https://cloudinary.com/console',
      },
    ],
  },
  {
    category: 'Studio',
    items: [
      {
        name: 'NYT Developer Portal',
        description: 'API key management for Metropolitan Diary.',
        href: 'https://developer.nytimes.com/my-apps',
      },
      {
        name: 'Flight Tracker',
        description: 'The embedded Fly.dev app — dashboard and deployments.',
        href: 'https://fly.io/dashboard/peter-hou',
      },
    ],
  },
  {
    category: 'Engagement',
    items: [
      {
        name: 'Formspree',
        description: 'Contact form submissions — inbox for messages left on the About page.',
        href: 'https://formspree.io/forms/xkoyzaqo',
      },
    ],
  },
  {
    category: 'Time Machine',
    items: [
      {
        name: 'Version 1 (2017–2023)',
        description: 'First version of my home.',
        href: 'https://vippeterhou.github.io/HomepageV1',
      },
      {
        name: 'Version 2 (2022–2026)',
        description: 'Second version of my home.',
        href: 'https://vippeterhou.github.io/HomepageV2',
      },
    ],
  },
]
---

<BaseLayout title="Manage — Peter Hou" description="Site management links">
  <section class="page-section">
    <div class="container">
      <h1 class="title">Manage</h1>
      <p class="subtitle">Quick links for managing the site.</p>

      <div class="sections">
        {services.map(group => (
          <div class="group">
            <h2 class="category">{group.category}</h2>
            <ul class="list">
              {group.items.map(item => (
                <li class="item">
                  <a href={item.href} target="_blank" rel="noopener" class="item-name">{item.name} ↗</a>
                  <p class="item-desc">{item.description}</p>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .title {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 0.25rem;
  }

  .subtitle {
    font-size: 0.9375rem;
    color: var(--text-muted);
    margin-bottom: 2.5rem;
  }

  .sections {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .category {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .item-name {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--accent);
    transition: opacity var(--transition);
  }

  .item-name:hover {
    opacity: 0.7;
  }

  .item-desc {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-top: 0.2rem;
    line-height: 1.5;
  }
</style>
