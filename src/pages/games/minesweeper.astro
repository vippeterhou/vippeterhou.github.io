---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Minesweeper from '../../components/Minesweeper.svelte'
---

<BaseLayout title="Minesweeper — Peter Hou" description="Classic Minesweeper game">
  <section class="page-section">
    <div class="container">
      <h1>Minesweeper</h1>
      <p class="sub">Left-click to reveal · Right-click to flag · Clear all mines to win.</p>
      <Minesweeper client:only="svelte" />
    </div>
  </section>
</BaseLayout>

<style>
  h1 {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .sub {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
  }
</style>
