---
import BaseLayout from '../layouts/BaseLayout.astro'
import Hero from '../components/Hero.svelte'

const cloudName = import.meta.env.CLOUDINARY_CLOUD_NAME
const apiKey    = import.meta.env.CLOUDINARY_API_KEY
const apiSecret = import.meta.env.CLOUDINARY_API_SECRET

let heroImages = []

try {
  const credentials = btoa(`${apiKey}:${apiSecret}`)

  const fetchFolder = async (folder) => {
    const res = await fetch(
      `https://api.cloudinary.com/v1_1/${cloudName}/resources/by_asset_folder?asset_folder=${encodeURIComponent(folder)}&max_results=100`,
      { headers: { Authorization: `Basic ${credentials}` } }
    )
    return res.json()
  }

  let data = await fetchFolder('main-desktop')
  if (!data.resources?.length) {
    data = await fetchFolder('Home/main-desktop')
  }

  heroImages = await Promise.all((data.resources ?? []).map(async r => {
    const lqipUrl = r.secure_url.replace('/upload/', '/upload/w_30,e_blur:500,q_10,f_auto/')
    const full    = r.secure_url.replace('/upload/', '/upload/q_auto,f_auto/')
    try {
      const res    = await fetch(lqipUrl)
      const buf    = await res.arrayBuffer()
      const mime   = res.headers.get('content-type') ?? 'image/jpeg'
      const lqip   = `data:${mime};base64,${Buffer.from(buf).toString('base64')}`
      return { lqip, full }
    } catch {
      return { lqip: lqipUrl, full }
    }
  }))
} catch {}
---

<BaseLayout title="Peter Hou">
  <Hero images={heroImages} client:load />
</BaseLayout>
