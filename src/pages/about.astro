---
import BaseLayout from '../layouts/BaseLayout.astro'
import ContactForm from '../components/ContactForm.svelte'
---

<BaseLayout title="About — Peter Hou" description="About Peter Hou">
  <section class="page-section">
    <div class="container">

      <div class="content">
        <p><strong>Hi, I'm Peter Hou.</strong> You found it.</p>
        <p>
          This homepage has gone through three iterations since 2017.
          The archived versions are still up if you're curious:
        </p>
        <ul class="versions">
          <li>
            Version 1 (2017–2023) — <a href="https://vippeterhou.github.io/HomepageV1" target="_blank" rel="noopener">view</a>
          </li>
          <li>
            Version 2 (2022–2026) — <a href="https://vippeterhou.github.io/HomepageV2" target="_blank" rel="noopener">view</a>
          </li>
        </ul>
      </div>

      <hr class="divider" />

      <div class="contact">
        <h2>Leave Me a Message</h2>
        <ContactForm client:load />
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  .content {
    font-size: 1rem;
    line-height: 1.8;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .versions {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding-left: 1rem;
  }

  .versions li::before {
    content: '→ ';
    color: var(--text-muted);
  }

  .versions a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .versions a:hover {
    color: var(--accent-hover);
  }

  .contact h2 {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--nav-color);
    margin-bottom: 1.25rem;
  }
</style>
