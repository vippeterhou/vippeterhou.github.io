---
import BaseLayout from '../layouts/BaseLayout.astro'
import ContactForm from '../components/ContactForm.svelte'
---

<BaseLayout title="About — Peter Hou" description="About Peter Hou">
  <section class="page-section">
    <div class="container">

      <div class="content">
        <p><strong>Hi, I'm Peter Hou.</strong> You found it!</p>
      </div>

      <hr class="divider" />

      <div class="contact">
        <h2>Leave Me a Message</h2>
        <ContactForm client:load />
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  .content {
    font-size: 1rem;
    line-height: 1.8;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact h2 {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--nav-color);
    margin-bottom: 1.25rem;
  }
</style>
