---
const year = new Date().getFullYear()
---

<footer>
  <p class="copy">
    Copyright &copy; 2017&ndash;{year} Peter Hou. All rights reserved.
  </p>
</footer>

<style>
  footer {
    padding: 1.25rem 1.5rem;
    border-top: 1px solid var(--border);
    background: var(--bg);
    text-align: center;
  }

  .copy {
    font-family: var(--font-display);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    color: var(--text-muted);
  }
</style>
